FoamFile
{
    version         2;
    format          ascii;
    class           volScalarField;
    location        "0";
    object          k;
}

dimensions      [ 0 2 -2 0 0 0 0 ];

internalField   uniform 0.00166667;

boundaryField
{
    "(inlet|outlet)"
    {
        type            cyclic;
    }
    walls
    {
        type            fixedValue;
        value           uniform 1e-10;
    }
}


