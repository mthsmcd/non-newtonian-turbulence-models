FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      zeta;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0.66;

boundaryField
{
    "(inlet|outlet)"
    {
        type            cyclic;
    }
    walls
    {
        type            fixedValue;
        value           uniform 1e-10;
    }
}


